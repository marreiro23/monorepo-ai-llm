{
  "name": "monorepo-ai-llm",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:monorepo-ai-llm": "nest build monorepo-ai-llm",
    "build:users-api": "nest build users-api",
    "build:llm-ops-api": "nest build llm-ops-api",
    "build:sharepoint-api": "nest build sharepoint-api",
    "build:sync-api": "nest build sync-api",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "mcp:mermaid:sync": "node tools/mcp/ensure-mermaid-domains.mjs",
    "mcp:mermaid:sync:all": "node tools/mcp/ensure-mermaid-domains.mjs",
    "mcp:org:check": "node tools/mcp/project-artifacts-organizer.mjs --action=check",
    "mcp:org:fix": "node tools/mcp/project-artifacts-organizer.mjs --action=fix",
    "mcp:org:new-runbook": "node tools/mcp/project-artifacts-organizer.mjs --action=new-runbook --operation=operacao-desenvolvimento",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/monorepo-ai-llm/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/monorepo-ai-llm/test/jest-e2e.json",
    "docker:build:all": "docker compose -f docker-compose.remote.yml --env-file .env.remote build",
    "docker:up:remote": "docker compose -f docker-compose.remote.yml --env-file .env.remote up -d",
    "docker:down:remote": "docker compose -f docker-compose.remote.yml --env-file .env.remote down",
    "docker:logs:remote": "docker compose -f docker-compose.remote.yml --env-file .env.remote logs -f --tail 200",
    "docker:ps:remote": "docker compose -f docker-compose.remote.yml --env-file .env.remote ps"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@datastax/astra-db-ts": "^2.2.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "typeorm": "^0.3.28",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}

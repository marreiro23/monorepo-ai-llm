# Copie este arquivo para .env.remote antes de subir os containers
# e ajuste portas/limites conforme a capacidade do servidor.

MONOREPO_AI_LLM_PORT=3000
USERS_API_PORT=3001
LLM_OPS_API_PORT=3002
SHAREPOINT_API_PORT=3003
SYNC_API_PORT=3004

# Limites conservadores para servidor Debian remoto
DEFAULT_MEMORY_LIMIT=512m
DEFAULT_MEMORY_RESERVATION=256m
DEFAULT_CPU_LIMIT=0.50

# PostgreSQL container
POSTGRES_DB=monorepo_ai_llm
POSTGRES_USER=monorepo
POSTGRES_PASSWORD=monorepo123
POSTGRES_PORT=5432
DATABASE_URL=postgresql://monorepo:monorepo123@postgres:5432/monorepo_ai_llm

# Auth base
AUTH_API_KEY=
AUTH_BEARER_TOKEN=

# Provider API keys
OPENAI_API_KEY=
CLAUDE_API_KEY=
ASTRADB_API_KEY=
LANGFLOW_API_KEY=

# GitHub + EntraID app registration with certificate thumbprint
ENTRA_GITHUB_CLIENT_ID=
ENTRA_GITHUB_TENANT_ID=
ENTRA_GITHUB_CERT_THUMBPRINT=
